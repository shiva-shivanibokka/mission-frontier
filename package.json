{
  "name": "mission-frontier",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Personal 3-month OpenAI Residency prep tracker: curated daily LeetCode (auto-synced from LeetCode), math, from-scratch build track, production coding, brain teasers, timed tests and interview-round readiness.",
  "scripts": {
